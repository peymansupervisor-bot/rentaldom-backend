{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "bundle": true,
        "externalModules": [
          "sharp",
          "firebase-admin",
          "firebase-admin/app",
          "firebase-admin/auth"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ]
}
