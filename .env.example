# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key          # Settings > API > service_role (never expose to client)
SUPABASE_STORAGE_BUCKET=keylink-media               # Create this bucket in Supabase Storage

# ── Twilio ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # Twilio Console > Verify > Services

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=a-long-random-secret-at-least-64-chars
JWT_EXPIRES_IN=30d

# ── Anthropic (Claude API) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Places API ─────────────────────────────────────
GOOGLE_PLACES_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Server ────────────────────────────────────────────────
PORT=4000
CLIENT_ORIGIN=http://localhost:8081              # Expo dev server or production app URL
